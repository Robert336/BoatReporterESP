            { "type": "value", "options": { "CONFIG":    { "color": "blue",   "index": 1 } } },
            { "type": "value", "options": { "ERROR":     { "color": "orange", "index": 2 } } },
            { "type": "value", "options": { "EMERGENCY": { "color": "red",    "index": 3 } } }
