      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb_boat" },
          "refId": "A",
          "query": "from(bucket: \"boat\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"boat_telemetry\" and r._field == \"state\")\n  |> filter(fn: (r) => r[\"device\"] =~ /${device:regex}/)\n  |> keep(columns: [\"_time\", \"_value\", \"device\"])"
        }
