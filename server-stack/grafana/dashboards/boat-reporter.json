    {
      "title": "System State",
      "type": "state-timeline",
      "datasource": { "type": "influxdb", "uid": "influxdb_boat" },
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 17 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "mappings": [
