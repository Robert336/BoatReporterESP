  "schemaVersion": 39,
  "tags": ["boat", "bilge"],
  "templating": {
    "list": [
      {
        "name": "device",
        "label": "Device",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "influxdb_boat" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"boat\", tag: \"device\")",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Boat Reporter — Bilge Monitor",
  "uid": "boat-reporter",
  "version": 2,
  "weekStart": "",
  "panels": [
    {
      "title": "Water Level",
      "type": "timeseries",
      "datasource": { "type": "influxdb", "uid": "influxdb_boat" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "lengthcm",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "spanNulls": true,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb_boat" },
          "refId": "A",
          "query": "from(bucket: \"boat\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"boat_telemetry\" and r._field == \"level_cm\")\n  |> filter(fn: (r) => r[\"device\"] =~ /${device:regex}/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"device\"])"
        }
      ]
    },
    {
      "title": "Current Level",
      "type": "stat",
      "datasource": { "type": "influxdb", "uid": "influxdb_boat" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "lengthcm",
          "decimals": 1,
