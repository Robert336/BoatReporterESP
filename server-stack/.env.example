# Copy this file to ".env" and change every value before launching.
#   cp .env.example .env

# ── InfluxDB ──────────────────────────────────────────────────────────────
INFLUX_USERNAME=admin
INFLUX_PASSWORD=change-me-influx-admin-pw
INFLUX_ORG=boat
INFLUX_BUCKET=boat
# Raw data older than this is dropped (e.g. 30d, 90d, 52w, 0s = keep forever).
INFLUX_RETENTION=90d
# All-access admin token. Generate a long random string, e.g.:
#   openssl rand -hex 32
INFLUX_TOKEN=change-me-to-a-long-random-token

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-pw

# ── MQTT auth (only needed once you switch on broker authentication / WAN) ──
# Telegraf uses these to log in to the broker. Create a matching broker user
# with scripts/mosquitto-passwd.sh. Leave blank for an anonymous LAN broker.
MQTT_USERNAME=
MQTT_PASSWORD=

# The public domain name that resolves to this Pi (used for the TLS cert and
# as the host you enter in the device UI). Only relevant for WAN/TLS setups.
MQTT_DOMAIN=mqtt.example.com

# ── Cloudflare DDNS (ddns/cloudflare-ddns.sh + scripts/issue-cert.sh) ──────
CF_API_TOKEN=your-cloudflare-api-token
CF_ZONE=example.com                  # root zone (e.g. example.com)
CF_RECORD=mqtt.example.com           # the full A record to keep updated
# Optional: seconds between cloudflare-ddns checks (default 300 if unset).
DDNS_INTERVAL=300
