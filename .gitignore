.pio
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Secrets file - contains sensitive credentials
include/secrets.h
secrets.h

# Auto-generated by scripts/compress_html.py at build time
src/compressed_pages.h

# Test logs (ignore large log files, keep summaries)
test-logs/*.log
test-logs/*.txt

# Server stack secrets (copy .env.example -> .env locally)
server-stack/.env
# TLS material, broker password file, certbot state, and DNS API creds
server-stack/certs/*
!server-stack/certs/.gitkeep
server-stack/letsencrypt/
server-stack/mosquitto/config/passwd
# Local broker backups / per-deployment config overrides (keep tracked templates only).
# The tracked acl is a commented template; real per-device entries are kept local
# via `git update-index --skip-worktree server-stack/mosquitto/config/acl`.
server-stack/mosquitto/config/*.bak
server-stack/secrets/*
!server-stack/secrets/cloudflare.ini.example